{
  "name": "@acp-autoform/core",
  "version": "4.0.1",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adityacodepublic/autoform.git"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --config ../../tsup.config.ts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --config ../../tsup.config.ts"
  },
  "devDependencies": {
    "@acp-autoform/eslint-config": "*",
    "@acp-autoform/typescript-config": "*",
    "@turbo/gen": "^1.12.4",
    "@types/eslint": "^8.56.5",
    "@types/node": "^20.11.24",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^8.57.0",
    "tsup": "^8.3.0",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
