{
  "name": "@autoform/core",
  "version": "3.0.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vantezzen/autoform"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "devDependencies": {
    "@autoform/eslint-config": "workspace:*",
    "@autoform/typescript-config": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
