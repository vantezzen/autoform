{
  "name": "@acp-autoform/react",
  "version": "7.0.0-beta.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react-hook-form": {
      "import": {
        "types": "./dist/react-hook-form/index.d.ts",
        "default": "./dist/react-hook-form/index.mjs"
      },
      "require": {
        "types": "./dist/react-hook-form/index.d.cts",
        "default": "./dist/react-hook-form/index.cjs"
      }
    },
    "./tanstack-form": {
      "import": {
        "types": "./dist/tanstack-form/index.d.ts",
        "default": "./dist/tanstack-form/index.mjs"
      },
      "require": {
        "types": "./dist/tanstack-form/index.d.cts",
        "default": "./dist/tanstack-form/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "build": "tsup src/index.tsx src/react-hook-form/index.ts src/tanstack-form/index.ts --format cjs,esm --dts --clean --external @acp-autoform/react --config ../../tsup.config.ts",
    "dev": "tsup src/index.tsx src/react-hook-form/index.ts src/tanstack-form/index.ts --format cjs,esm --dts --watch --external @acp-autoform/react --config ../../tsup.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adityacodepublic/autoform.git"
  },
  "devDependencies": {
    "@acp-autoform/eslint-config": "*",
    "@acp-autoform/typescript-config": "*",
    "@hookform/resolvers": "^5.1.1",
    "@tanstack/react-form": "^1",
    "@turbo/gen": "^1.12.4",
    "@types/eslint": "^8.56.5",
    "@types/node": "^20.11.24",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^8.57.0",
    "react": "^19.1.0",
    "react-hook-form": "^7",
    "tsup": "^8.3.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@acp-autoform/core": "^4.0.0"
  },
  "peerDependencies": {
    "@hookform/resolvers": "^3.9.0 || ^4 || ^5",
    "@tanstack/react-form": "^1",
    "react": "^17 || ^18 || ^19",
    "react-hook-form": "^7"
  },
  "peerDependenciesMeta": {
    "react-hook-form": {
      "optional": true
    },
    "@hookform/resolvers": {
      "optional": true
    },
    "@tanstack/react-form": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
