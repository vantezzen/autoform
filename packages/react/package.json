{
  "name": "@dual-autoform/react",
  "version": "1.0.1",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./react-hook-form": {
      "import": {
        "types": "./dist/react-hook-form/index.d.ts",
        "default": "./dist/react-hook-form/index.mjs"
      },
      "require": {
        "types": "./dist/react-hook-form/index.d.ts",
        "default": "./dist/react-hook-form/index.cjs"
      }
    },
    "./tanstack-form": {
      "import": {
        "types": "./dist/tanstack-form/index.d.ts",
        "default": "./dist/tanstack-form/index.mjs"
      },
      "require": {
        "types": "./dist/tanstack-form/index.d.ts",
        "default": "./dist/tanstack-form/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adityacodepublic/autoform.git"
  },
  "devDependencies": {
    "@dual-autoform/eslint-config": "workspace:*",
    "@dual-autoform/typescript-config": "workspace:*",
    "@hookform/resolvers": "^5.1.1",
    "@tanstack/react-form": "^1",
    "react": "^19.2.6",
    "react-hook-form": "^7"
  },
  "dependencies": {
    "@dual-autoform/core": "workspace:^"
  },
  "peerDependencies": {
    "@hookform/resolvers": "^3.9.0 || ^4 || ^5",
    "@tanstack/react-form": "^1",
    "react": "^17 || ^18 || ^19",
    "react-hook-form": "^7"
  },
  "peerDependenciesMeta": {
    "react-hook-form": {
      "optional": true
    },
    "@hookform/resolvers": {
      "optional": true
    },
    "@tanstack/react-form": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
