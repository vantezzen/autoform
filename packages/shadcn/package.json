{
  "name": "@dual-autoform/shadcn",
  "version": "1.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "build": "tsx src/scripts/build.ts && cd ../.. && npx --yes shadcn@latest build registry.json --output packages/shadcn/registry && cd packages/shadcn && tsx src/scripts/build-react-source-registry.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adityacodepublic/autoform.git"
  },
  "exports": {
    "./globals.css": "./src/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./tailwind.config": "./tailwind.config.ts",
    "./lib/*": "./src/lib/*.ts",
    "./hooks/*": "./src/hooks/*.ts",
    "./components/*": "./src/components/*.tsx"
  },
  "devDependencies": {
    "@dual-autoform/eslint-config": "workspace:*",
    "@dual-autoform/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.1.10",
    "autoprefixer": "^10",
    "glob": "^11.0.3",
    "postcss": "^8",
    "postcss-load-config": "^6",
    "react": "^19.2.6",
    "react-hook-form": "^7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "*",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.22.4",
    "zod": "^4.0.10"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "*",
    "react-day-picker": "^10.0.1"
  },
  "peerDependencies": {
    "@dual-autoform/react": "workspace:*",
    "react": "^16.8.0 || ^17 || ^18 || ^19",
    "zod": "^3"
  }
}
