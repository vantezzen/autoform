        "default": "./dist/react-hook-form.cjs"
      }
    },
    "./tanstack-form": {
      "import": {
        "types": "./dist/tanstack-form.d.mts",
        "default": "./dist/tanstack-form.mjs"
      },
      "require": {
        "types": "./dist/tanstack-form.d.cts",
        "default": "./dist/tanstack-form.cjs"
      }
    },
    "./package.json": "./package.json"
