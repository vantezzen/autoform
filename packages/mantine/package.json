{
  "name": "@dual-autoform/mantine",
  "version": "1.0.1",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./react-hook-form": {
      "import": {
        "types": "./dist/react-hook-form.d.ts",
        "default": "./dist/react-hook-form.mjs"
      },
      "require": {
        "types": "./dist/react-hook-form.d.ts",
        "default": "./dist/react-hook-form.cjs"
      }
    },
    "./tanstack-form": {
      "import": {
        "types": "./dist/tanstack-form.d.ts",
        "default": "./dist/tanstack-form.mjs"
      },
      "require": {
        "types": "./dist/tanstack-form.d.ts",
        "default": "./dist/tanstack-form.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adityacodepublic/autoform.git"
  },
  "devDependencies": {
    "@dual-autoform/core": "workspace:*",
    "@dual-autoform/eslint-config": "workspace:*",
    "@dual-autoform/typescript-config": "workspace:*",
    "@mantine/core": "^7.16.0",
    "@mantine/dates": "^7.16.0",
    "react": "^19.2.6"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.0.0"
  },
  "peerDependencies": {
    "@dual-autoform/react": "workspace:^",
    "@mantine/core": "^7",
    "@mantine/dates": "^7",
    "react": "^18 || ^19"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
