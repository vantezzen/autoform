{
  "name": "@acp-autoform/chakra",
  "version": "4.0.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./src/index.tsx",
  "exports": {
    ".": {
      "import": {
        "types": "./src/index.tsx",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./src/index.tsx",
        "default": "./dist/index.cjs"
      }
    },
    "./react-hook-form": {
      "import": {
        "types": "./src/react-hook-form.tsx",
        "default": "./dist/react-hook-form.mjs"
      },
      "require": {
        "types": "./src/react-hook-form.tsx",
        "default": "./dist/react-hook-form.cjs"
      }
    },
    "./tanstack-form": {
      "import": {
        "types": "./src/tanstack-form.tsx",
        "default": "./dist/tanstack-form.mjs"
      },
      "require": {
        "types": "./src/tanstack-form.tsx",
        "default": "./dist/tanstack-form.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adityacodepublic/autoform.git"
  },
  "devDependencies": {
    "@acp-autoform/core": "workspace:*",
    "@acp-autoform/eslint-config": "workspace:*",
    "@acp-autoform/typescript-config": "workspace:*",
    "@chakra-ui/react": "^3.8.1",
    "@emotion/react": "^11.14.0",
    "react": "^19.2.6",
    "react-icons": "^5.4.0"
  },
  "dependencies": {
    "next-themes": "^0.4.4"
  },
  "peerDependencies": {
    "@acp-autoform/react": "workspace:^",
    "@chakra-ui/react": "^3.8",
    "@emotion/react": "^11.14",
    "react": "^18 || ^19"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
