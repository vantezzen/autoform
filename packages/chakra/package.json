{
  "name": "@acp-autoform/chakra",
  "version": "3.0.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react-hook-form": {
      "types": "./dist/react-hook-form.d.ts",
      "import": "./dist/react-hook-form.mjs",
      "require": "./dist/react-hook-form.js"
    },
    "./tanstack-form": {
      "types": "./dist/tanstack-form.d.ts",
      "import": "./dist/tanstack-form.mjs",
      "require": "./dist/tanstack-form.js"
    }
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "build": "tsup src/index.tsx src/react-hook-form.tsx src/tanstack-form.tsx --format cjs,esm --dts",
    "dev": "tsup src/index.tsx src/react-hook-form.tsx src/tanstack-form.tsx --format cjs,esm --dts --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adityacodepublic/autoform.git"
  },
  "devDependencies": {
    "@acp-autoform/core": "*",
    "@acp-autoform/eslint-config": "*",
    "@acp-autoform/typescript-config": "*",
    "@chakra-ui/react": "^3.8.1",
    "@emotion/react": "^11.14.0",
    "@types/eslint": "^8.56.5",
    "@types/node": "^20.11.24",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^8.57.0",
    "react": "^19.1.0",
    "react-icons": "^5.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@acp-autoform/react": "*",
    "next-themes": "^0.4.4"
  },
  "peerDependencies": {
    "@chakra-ui/react": "^3.8",
    "@emotion/react": "^11.14",
    "react": "^16.8.0 || ^17 || ^18 || ^19"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
