{
  "name": "acp-autoform",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --concurrency 20",
    "lint": "turbo lint",
    "check:packages": "node scripts/check-package-boundaries.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "cypress": "turbo run cypress --filter=web",
    "cypress:dev": "turbo run cypress --filter=web --parallel"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.1.3",
    "typescript": "^5.4.5"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.2.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@changesets/cli": "^2.27.9"
  }
}
